{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glossa",
  "version": "0.3.0",
  "identifier": "dev.xy6.glossa",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Glossa",
        "width": 1640,
        "height": 1050,
        "minWidth": 960,
        "minHeight": 640,
        "transparent": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
